    <script src="/static/js/srun.portal.lang.js?v=2.00.20220802"></script>
    <script src="/static/js/jquery.srun.portal.js?v=2.00.20220802"></script>
    <script src="/static/js/main.js?v=2.00.20220802"></script>
    <script>
        (function () {
            

            var setCookie = function (name, value, day) {
                if (day === undefined) day = 7;
                var date = new Date();
                date.setDate(date.getDate() + day);
                document.cookie = name + '=' + value + ';expires=' + date;
            };

            

            var getCookie = function (name) {
                var reg = RegExp(name + '=([^;]+)'),
                    arr = document.cookie.match(reg);

                if (arr) {
                    return arr[1];
                } else {
                    return false;
                }
            };

            

            var delCookie = function (name) {
                setCookie(name, '', -1);
            };

            var cookie = {
                user: getCookie('user'),
                pass: getCookie('pass')
            };

            if (cookie.user) {
                $('#username').val(cookie.user);
                $.base64.setAlpha('LVoJPiCN2R8G90yg+hmFHuacZ1OWMnrsSTXkYpUq/3dlbfKwv6xztjI7DeBE45QA');
                $('#password').val($.base64.decode(cookie.pass));
                $('#remember').get(0).checked = true;
            }

            $('#login').click(function () {
                var remember = document.getElementById('remember');
                if (remember) {
                    $.base64.setAlpha('LVoJPiCN2R8G90yg+hmFHuacZ1OWMnrsSTXkYpUq/3dlbfKwv6xztjI7DeBE45QA');
                    var login = {
                        remember: $('#remember').get(0).checked,
                        user: $('#username').val(),
                        pass: $.base64.encode($('#password').val())
                    };
                    if (login.remember) {
                        setCookie('user', login.user);
                        setCookie('pass', login.pass);
                    } else {
                        delCookie('user');
                        delCookie('pass');
                    }
                }
            });
        })()
    </script>
</body>

